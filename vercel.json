{
  "name": "flightpath",
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "env": {
    "NEXT_PUBLIC_APP_URL": "https://flightpath.solutions"
  },
  "functions": {
    "app/api/combined-search/route.ts": {
      "maxDuration": 300
    },
    "app/api/scrape-v2/route.ts": {
      "maxDuration": 120
    },
    "app/api/deep-research/route.ts": {
      "maxDuration": 300
    }
  }
}
